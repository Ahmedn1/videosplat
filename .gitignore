# Heavy / generated artifacts (local only)
# data/    input datasets (N3V, etc.) ~44 GB
# outputs/ trained models, keyframes, viewers ~68 GB
# .venv/   virtualenv ~8 GB
data/
outputs/
.venv/

# Researcher skill (untracked source of truth) + its archived backups
.lab/
.lab.bak*/
run.log
output.png

# Big binaries anywhere — EXCEPT the committed demo assets under docs/
*.ply
*.mp4
*.splat
*.ksplat
!docs/**

# Stray generated frames dumped at cwd by the 4DGaussians dynerf reader
/images/

# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/

# Local agent / editor state
.claude/
.vscode/
.idea/
*.swp
